{
  "actorSpecification": 1,
  "fields": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "originalFeedback": {
        "type": "string",
        "title": "Original Feedback",
        "description": "The raw feedback, complaint, or evaluation text provided by the user.",
        "example": "His work is a mess. Deadlines keep slipping."
      },
      "improvedFeedback": {
        "type": "string",
        "title": "Improved Feedback",
        "description": "The feedback refined by SCDFT with total clarity, honesty, and structured, professional language.",
        "example": "Andre is facing serious challenges in consistently meeting deadlines."
      },
      "toneUsed": {
        "type": "string",
        "title": "Tone Used",
        "description": "The tone applied to the feedback.",
        "example": "honest and constructive"
      },
      "status": {
        "type": "string",
        "title": "Status",
        "description": "The success or failure status of the processing.",
        "enum": ["success", "error"],
        "example": "success"
      },
      "timestamp": {
        "type": "string",
        "title": "Timestamp",
        "description": "The processing timestamp in ISO 8601 format.",
        "example": "2026-05-04T10:30:00.000Z"
      },
      "auditHash": {
        "type": "string",
        "title": "Audit Hash",
        "description": "SHA-256 hash of originalFeedback + improvedFeedback + timestamp for audit trail and EU AI Act compliance.",
        "example": "a3f2b8c9d1e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9"
      },
      "download_docx": {
        "type": "string",
        "title": "Download DOCX",
        "description": "URL to download the improved feedback as a Microsoft Word (.docx) file.",
        "example": "https://api.apify.com/v2/key-value-stores/STORE_ID/records/feedback_1_a3f2b8c9.docx"
      },
      "download_pdf": {
        "type": "string",
        "title": "Download PDF",
        "description": "URL to download the improved feedback as a PDF file.",
        "example": "https://api.apify.com/v2/key-value-stores/STORE_ID/records/feedback_1_a3f2b8c9.pdf"
      },
      "originalSubject": {
        "type": "string",
        "title": "Original Subject",
        "description": "Original feedback subject line.",
        "example": "Performance Review Q1"
      },
      "recipientName": {
        "type": "string",
        "title": "Recipient Name",
        "description": "Name of the recipient.",
        "example": "Andre"
      },
      "senderName": {
        "type": "string",
        "title": "Sender Name",
        "description": "Name of the sender.",
        "example": "Manager"
      },
      "recipientEmail": {
        "type": "string",
        "title": "Recipient Email",
        "description": "Email address of the recipient.",
        "example": "andre@example.com"
      },
      "context": {
        "type": "string",
        "title": "Context",
        "description": "The context of the feedback (e.g., performance review, customer complaint, product review, public report).",
        "example": "performance review"
      }
    },
    "required": ["originalFeedback", "improvedFeedback", "status", "auditHash", "download_docx", "download_pdf"]
  },
  "views": {
    "overview": {
      "title": "SCDFT Feedback Refinement Results",
      "transformation": {
        "fields": [
          "originalFeedback",
          "improvedFeedback",
          "toneUsed",
          "status",
          "timestamp",
          "auditHash",
          "download_docx",
          "download_pdf",
          "originalSubject",
          "recipientName",
          "senderName",
          "recipientEmail",
          "context"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "originalFeedback": { "label": "Original Feedback", "format": "text" },
          "improvedFeedback": { "label": "Improved Feedback", "format": "text" },
          "toneUsed": { "label": "Tone", "format": "text" },
          "status": { "label": "Status", "format": "text" },
          "timestamp": { "label": "Time", "format": "text" },
          "auditHash": { "label": "Audit Hash", "format": "text" },
          "download_docx": { "label": "Download DOCX", "format": "text" },
          "download_pdf": { "label": "Download PDF", "format": "text" },
          "originalSubject": { "label": "Original Subject", "format": "text" },
          "recipientName": { "label": "Recipient", "format": "text" },
          "senderName": { "label": "Sender", "format": "text" },
          "recipientEmail": { "label": "Recipient Email", "format": "text" },
          "context": { "label": "Context", "format": "text" }
        }
      }
    }
  }
}
